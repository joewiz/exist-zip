<package xmlns="http://expath.org/ns/pkg" name="${package-name}" abbrev="${package-abbrev}" version="${project.version}"
    spec="1.0">
    <title>${package-title}</title>
    <author id="exist-db">eXist-db</author>
    <website>${project.url}</website>
    <license>GNU Lesser General Public License, version 2.1</license>
    <copyright>true</copyright>

    <type>library</type>

    <status>stable</status>

    <tag>${project.artifactId}</tag>
    <tag>library</tag>
    <tag>zip</tag>
    <tag>expath</tag>
    <category id="libs">Libraries</category>

    <dependency processor="http://exist-db.org" semver-min="7.0.0" />

    <target>${package-abbrev}</target>

    <!-- include the XQuery Library Module written in Java (JAR output) from this project -->
    <dependencySets>
        <dependencySet>
            <groupId>${project.groupId}</groupId>
            <artifactId>${project.artifactId}</artifactId>
            <version>${project.version}</version>
        </dependencySet>
    </dependencySets>

    <!-- register the Java module to eXist-db -->
    <components>
        <resource>
            <public-uri>${zip.module.namespace}</public-uri>
            <file>urn:java:class:org.exist.xquery.modules.zip.${zip.module.java.classname}</file>
        </resource>
    </components>

</package>
