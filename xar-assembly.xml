<?xml version="1.0" encoding="UTF-8"?>
<package xmlns="http://expath.org/ns/pkg"
         name="${package-name}"
         abbrev="${package-abbrev}"
         version="${project.version}"
         spec="1.0">
    <title>${project.name}</title>
    <description>${project.description}</description>
    <author id="exist-db">${project.organization.name}</author>
    <website>${project.url}</website>
    <license>GNU Lesser General Public License, version 2.1</license>
    <copyright>true</copyright>

    <type>library</type>

    <status>stable</status>

    <tag>${project.artifactId}</tag>
    <tag>zip</tag>
    <tag>expath</tag>
    <tag>archive</tag>
    <category id="libs">Libraries</category>

    <dependency processor="http://exist-db.org" semver-min="6.0.0"/>

    <target>${package-abbrev}</target>

    <fileSets>
        <fileSet>
            <directory>${basedir}</directory>
            <includes>
                <include>README.md</include>
                <include>LICENSE</include>
            </includes>
        </fileSet>
    </fileSets>

    <!-- include the Java module JAR from this project -->
    <dependencySets>
        <dependencySet>
            <groupId>${project.groupId}</groupId>
            <artifactId>${project.artifactId}</artifactId>
            <version>${project.version}</version>
        </dependencySet>
    </dependencySets>

    <!-- register the Java module to eXist-db -->
    <components>
        <resource>
            <public-uri>${zip.module.namespace}</public-uri>
            <file>urn:java:class:${zip.module.java.classname}</file>
        </resource>
    </components>

    <changelog>
        <change xmlns="http://exist-db.org/xquery/repo" version="1.0.0">
            <ul xmlns="http://www.w3.org/1999/xhtml">
                <li>Initial release as standalone EXPath package</li>
                <li>Functions: zip:binary-entry, zip:text-entry, zip:xml-entry, zip:html-entry, zip:entries, zip:zip-file, zip:update-entries</li>
                <li>Replaces tools-java dependency with native java.util.zip</li>
            </ul>
        </change>
    </changelog>
</package>
